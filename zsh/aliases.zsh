alias reload!='. ~/.zshrc'

alias cls='clear' # Good 'ol Clear Screen command

alias ls='eza --color=always' # List files with colors
alias ll='eza -l --color=always' # List files with colors
alias la='eza -la --color=always' # List all files with colors
alias l='eza -l --color=always' # List files with colors
alias lsd='eza -l --color=always --group-directories-first' # List directories first
alias lsa='eza -la --color=always --group-directories-first' # List all files with colors and directories first

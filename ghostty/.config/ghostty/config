# theme = TokyoNight
theme = dark:Builtin Solarized Light,light:Builtin Solarized Dark
clipboard-read = allow
clipboard-write = allow
copy-on-select = true
font-family = BlexMono Nerd Font Mono
font-size = 12

# Launch Zellij automatically (attach to 'main' or create it)
# command = zsh -ic "zellij attach main -c"

# Quick terminal for macOS
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-autohide = true
keybind = global:cmd+grave_accent=toggle_quick_terminal
keybind = shift+enter=text:\x1b[13;2u

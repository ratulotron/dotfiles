# --- Appearance ---
theme = dark:Monokai Pro Machine,light:Monokai Pro Light Sun
font-size = 16
font-family = "BlexMono Nerd Font Mono"

# Background settings
background-opacity = 0.85
# Note: if blur-radius still fails, try: background-blur = true
background-blur-radius = 20

cursor-style = block
cursor-style-blink = false

# --- Window & UI ---
window-padding-x = 10
window-padding-y = 10
macos-titlebar-style = transparent
window-save-state = always
confirm-close-surface = false
window-theme = system
# macos-titlebar-style = tabs


# --- Editing ---
clipboard-read = allow
clipboard-write = allow
copy-on-select = true

# --- UX ---
quick-terminal-position = bottom
quick-terminal-screen = main
quick-terminal-autohide = true

# --- Keybindings ---
keybind = global:cmd+grave_accent=toggle_quick_terminal
keybind = shift+enter=text:\x1b[13;2u
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

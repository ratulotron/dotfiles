# Local/private config goes in the include
[include]
        path = ~/.gitconfig.local
        path = ~/.gitconfig.machine
[hub]
        protocol = https
[alias]
        # Basic shortcuts
        co = checkout
        br = branch
        ci = commit
        st = status

        # Enhanced shortcuts
        promote = !$DOTFILES/bin/git-promote
        wtf     = !$DOTFILES/bin/git-wtf
        rank-contributors = !$DOTFILES/bin/git-rank-contributors
        count   = !git shortlog -sn

        # Useful aliases from popular dotfiles
        unstage = reset HEAD --
        last = log -1 HEAD
        visual = !gitk

        # Branch management
        branches = branch -a
        remotes = remote -v

        # Enhanced logging
        lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
        ll = log --oneline --decorate --graph --all

        # Diff aliases
        dt = difftool
        mt = mergetool

        # Stash shortcuts
        ss = stash save
        sp = stash pop
        sl = stash list

        # Quick commit shortcuts
        amend = commit --amend --no-edit
        wip = commit -am 'WIP'

        # Sync shortcuts
        sync = !git fetch origin && git rebase origin/main
        up = !git pull --rebase --prune $@ && git submodule update --init --recursive
[color]
        diff = auto
        status = auto
        branch = auto
        ui = true
[core]
        excludesfile = ~/.gitignore
        editor = hx
	pager = delta
[apply]
        whitespace = nowarn
[mergetool]
        keepBackup = false
[difftool]
        prompt = false
[help]
        autocorrect = 1
[push]
        # See `git help config` (search for push.default)
        # for more information on different options of the below setting.
        #
        # Setting to git 2.0 default to suppress warning message
        default = simple
[init]
	defaultBranch = main
[user]
	email = minhaz.ratul@gmail.com
	name = Ratul Minhaz
[pull]
	rebase = true
[fetch]
	prune = true
[rebase]
	autoStash = true
[diff]
	algorithm = histogram
[interactive]
	diffFilter = delta --color-only

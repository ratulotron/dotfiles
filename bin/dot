#!/bin/sh
#
# dot
#
# Main dotfiles management interface. Provides comprehensive dotfiles operations
# including installation, updates, maintenance, and troubleshooting.

set -e

export DOTFILES="${DOTFILES:-$HOME/.dotfiles}"

# Handle legacy options and delegate to script/dotfiles
case "${1:-}" in
    "-e"|"--edit")
        exec "$EDITOR" "$DOTFILES"
        ;;
    "-h"|"--help"|"help")
        exec "$DOTFILES/script/dotfiles" help
        ;;
    "")
        # Default behavior: run comprehensive update
        exec "$DOTFILES/script/dotfiles" update
        ;;
    *)
        # Pass all other commands to script/dotfiles
        exec "$DOTFILES/script/dotfiles" "$@"
        ;;
esac

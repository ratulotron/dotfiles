#!/bin/sh
#
# dot
#
# Main dotfiles management interface. Wraps the Makefile.

set -e

export DOTFILES="${DOTFILES:-$HOME/.dotfiles}"

case "${1:-}" in
    "install")
        make -C "$DOTFILES" install
        ;;
    "update")
        make -C "$DOTFILES" update
        ;;
    "stow")
        make -C "$DOTFILES" stow
        ;;
    "check")
        make -C "$DOTFILES" check
        ;;
    "clean")
        make -C "$DOTFILES" clean
        ;;
    "-e"|"--edit"|"edit")
        exec "$EDITOR" "$DOTFILES"
        ;;
    "-h"|"--help"|"help")
        echo "Usage: dot [command]"
        echo ""
        echo "Commands:"
        echo "  install   Install dependencies"
        echo "  update    Update dotfiles (pull + install + stow)"
        echo "  stow      Stow packages (link files)"
        echo "  check     Dry-run stow and detect legacy links"
        echo "  clean     Remove symlinks"
        echo "  edit      Open dotfiles in editor"
        ;;
    "")
        # Default behavior: run comprehensive update
        make -C "$DOTFILES" update
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'dot help' for usage."
        exit 1
        ;;
esac

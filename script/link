#!/usr/bin/env bash
#
# Simple Modular Link Script - Cleaner version
# 

set -e
cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

# Load UI functions
source "script/modules/ui.sh"
source "script/modules/file_ops.sh"

# Simple pattern processing - one function per use case
link_topic() {
    local topic=$1
    local dry_run=$2
    local count=0
    
    info "Processing topic: $topic"
    
    # Use Case 1: Home directory files
    for src in "$DOTFILES_ROOT/$topic"/*.symlink; do
        [ -f "$src" ] || continue
        local filename=$(basename "${src%.symlink}")
        local dst="$HOME/.$filename"
        
        if [ "$dry_run" = "true" ]; then
            info "[DRY RUN] Would link: $src -> $dst"
        else
            link_file "$src" "$dst"
        fi
        count=$((count + 1))
    done
    
    # Use Case 2: Config directory
    local config_dir="$DOTFILES_ROOT/$topic/config/$topic.symlink.d"
    if [ -d "$config_dir" ]; then
        local dst="$HOME/.config/$topic"
        
        # Skip if already correctly symlinked
        if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$config_dir" ]; then
            # Already correctly linked, skip silently
            count=$((count + 1))
        elif [ "$dry_run" = "true" ]; then
            info "[DRY RUN] Would link directory: $config_dir -> $dst"
        else
            mkdir -p "$(dirname "$dst")"
            link_file "$config_dir" "$dst"
        fi
        count=$((count + 1))
    fi
    
    # Use Case 3: Config files - topic/config/[filename].symlink → ~/.config/[filename]
    for src in "$DOTFILES_ROOT/$topic/config"/*.symlink; do
        [ -f "$src" ] || continue
        local filename=$(basename "${src%.symlink}")
        local dst="$HOME/.config/$filename"
        
        if [ "$dry_run" = "true" ]; then
            info "[DRY RUN] Would link: $src -> $dst"
        else
            mkdir -p "$(dirname "$dst")"
            link_file "$src" "$dst"
        fi
        count=$((count + 1))
    done
    
    # Use Case 4: Bin files
    if [ -d "$DOTFILES_ROOT/$topic/bin" ]; then
        for src in "$DOTFILES_ROOT/$topic/bin"/*; do
            [ -f "$src" ] || continue
            local filename=$(basename "$src")
            local dst="$HOME/.local/bin/$filename"
            
            if [ "$dry_run" = "true" ]; then
                info "[DRY RUN] Would link: $src -> $dst"
            else
                mkdir -p "$(dirname "$dst")"
                link_file "$src" "$dst"
            fi
            count=$((count + 1))
        done
    fi
    
    # Use Case 5: Custom script
    if [ -f "$DOTFILES_ROOT/$topic/link.sh" ]; then
        if [ "$dry_run" = "true" ]; then
            info "[DRY RUN] Would execute: $DOTFILES_ROOT/$topic/link.sh"
        else
            info "Running custom linking for $topic"
            (cd "$DOTFILES_ROOT/$topic" && ./link.sh)
        fi
        count=$((count + 1))
    fi
    
    if [ $count -gt 0 ]; then
        info "Processed $count items for $topic"
        success "Completed processing $topic"
        return 0
    else
        info "No linking rules found for $topic"
        return 1
    fi
}

# Main function
main() {
    local dry_run=$1
    local topics_linked=0
    
    info "Universal dotfiles linking"
    
    for topic_dir in "$DOTFILES_ROOT"/*/; do
        [ -d "$topic_dir" ] || continue
        local topic=$(basename "$topic_dir")
        
        # Skip special directories
        case "$topic" in
            .git|script) continue ;;
        esac
        
        if link_topic "$topic" "$dry_run"; then
            topics_linked=$((topics_linked + 1))
        fi
    done

    if [ "$dry_run" = "true" ]; then
        info "Dry run complete. Found $topics_linked topics to process."
        info "Run without --dry-run to apply changes."
    else
        success "Universal linking complete! Processed $topics_linked topics."
    fi
}

# Parse arguments
DRY_RUN=false
for arg in "$@"; do
    case $arg in
        --dry-run) DRY_RUN=true; info "Running in dry-run mode - no changes will be made" ;;
        --help|-h) 
            echo "Usage: $0 [--dry-run] [--help]"
            echo "Simplified modular dotfiles linker"
            exit 0 ;;
    esac
done

main "$DRY_RUN"
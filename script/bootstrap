#!/usr/bin/env bash
#
# Bootstrap dotfiles - orchestrates initialization, installation, and linking

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

set -e

echo ''
echo '› Bootstrapping dotfiles...'

info () {
  printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

user () {
  printf "\r  [ \033[0;33m??\033[0m ] $1\n"
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
  echo ''
  exit
}

setup_gitconfig () {
  if ! [ -f git/gitconfig.local.symlink ]
  then
    info 'setup gitconfig'

    git_credential='cache'
    if [ "$(uname -s)" == "Darwin" ]
    then
      git_credential='osxkeychain'
    fi

    user ' - What is your github author name?'
    read -e git_authorname
    user ' - What is your github author email?'
    read -e git_authoremail

    sed -e "s/AUTHORNAME/$git_authorname/g" -e "s/AUTHOREMAIL/$git_authoremail/g" -e "s/GIT_CREDENTIAL_HELPER/$git_credential/g" git/gitconfig.local.symlink.example > git/gitconfig.local.symlink

    success 'gitconfig'
  fi
}

# Parse command line arguments
DRY_RUN=false
for arg in "$@"; do
  case $arg in
    --dry-run)
      DRY_RUN=true
      info "Running in dry-run mode - no changes will be made"
      shift
      ;;
    --help|-h)
      echo "Usage: $0 [--dry-run] [--help]"
      echo ""
      echo "  --dry-run    Show what would be done without making changes"
      echo "  --help       Show this help message"
      exit 0
      ;;
  esac
done

# 1. Initialization - setup git configuration
echo '› Phase 1: Initialization'
setup_gitconfig

# 2. Installation - install all tools and dependencies
echo '› Phase 2: Installation'
if [ "$DRY_RUN" = "true" ]; then
  script/install --dry-run
else
  script/install
fi

# 3. System Configuration - setup system-specific configs
echo '› Phase 3: System Configuration'
if [ "$DRY_RUN" = "true" ]; then
  info "[DRY RUN] Would configure system settings"
else
  # Suppress Podman Docker emulation message on Linux
  if command -v podman >/dev/null 2>&1 && [ ! -f /etc/containers/nodocker ]; then
    info "Configuring Podman to suppress Docker emulation message"
    if sudo -n true 2>/dev/null; then
      # Can sudo without password
      sudo mkdir -p /etc/containers
      sudo touch /etc/containers/nodocker
      success "Podman Docker emulation message suppressed"
    else
      # Need to ask for password
      info "Creating /etc/containers/nodocker to suppress Podman Docker emulation message"
      if sudo mkdir -p /etc/containers && sudo touch /etc/containers/nodocker; then
        success "Podman Docker emulation message suppressed"
      else
        info "Could not create /etc/containers/nodocker - you may see Podman messages"
      fi
    fi
  fi
fi

# 4. Linking - create all symlinks
echo '› Phase 4: Linking'
if [ "$DRY_RUN" = "true" ]; then
  script/link --dry-run
else
  script/link
fi

echo ''
success 'Bootstrap complete!'

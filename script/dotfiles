#!/usr/bin/env bash
#
# Dotfiles management utility - one script to rule them all

set -e

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

info () {
  printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

show_help() {
  cat << EOF
dotfiles - Manage your dotfiles configuration

USAGE:
    ./script/dotfiles <command> [options]

COMMANDS:
    bootstrap       Complete dotfiles setup (initialization → installation → linking)
    install         Install tools and dependencies only
    link            Create symlinks only
    update          Comprehensive update: repo, macOS, Homebrew, packages
    backup          Create backup of current dotfiles
    restore         Restore from backup
    clean           Remove broken symlinks and old backup files
    list            List all managed dotfiles
    help            Show this help message

OPTIONS:
    --dry-run       Show what would be done (for bootstrap/install/link)
    --force         Skip confirmations (for backup/restore)

EXAMPLES:
    ./script/dotfiles bootstrap --dry-run  # Preview complete setup
    ./script/dotfiles install --dry-run    # Preview tool installation
    ./script/dotfiles link --dry-run       # Preview symlink creation
    ./script/dotfiles update               # Update packages
EOF
}

cmd_bootstrap() {
  info "Bootstrapping dotfiles..." 
  script/bootstrap "$@"
}

cmd_install() {
  info "Installing tools and dependencies..."
  script/install "$@"
}

cmd_link() {
  info "Linking dotfiles..."
  script/link "$@"
}

cmd_update() {
  info "Running comprehensive dotfiles update..."
  
  # Update dotfiles repository
  info "Updating dotfiles repository..."
  git -C "$DOTFILES" pull
  success "Dotfiles repository updated"
  
  # Set macOS defaults
  if [[ "$OSTYPE" == "darwin"* ]]; then
    info "Applying macOS defaults..."
    "$DOTFILES/macos/set-defaults.sh"
    success "macOS defaults applied"
    
    info "Setting macOS hostname..."
    "$DOTFILES/macos/set-hostname.sh"
    success "macOS hostname configured"
  fi
  
  # Install/update Homebrew
  if [[ "$OSTYPE" == "darwin"* ]]; then
    info "Installing/updating Homebrew..."
    "$DOTFILES/homebrew/install.sh" 2>&1
    
    if command -v brew >/dev/null 2>&1; then
      info "Updating Homebrew packages..."
      brew update && brew upgrade
      success "Homebrew updated"
    fi
  fi
  
  # Install software packages
  info "Installing/updating software packages..."
  "$DOTFILES/script/install"
  success "Software packages updated"
  
  # Apply system configuration
  info "Applying system configuration..."
  if command -v podman >/dev/null 2>&1 && [ ! -f /etc/containers/nodocker ]; then
    info "Configuring Podman to suppress Docker emulation message"
    if sudo -n true 2>/dev/null || sudo mkdir -p /etc/containers && sudo touch /etc/containers/nodocker; then
      success "Podman Docker emulation message suppressed"
    else
      info "Could not create /etc/containers/nodocker - you may see Podman messages"
    fi
  fi
  
  # Update Oh My Zsh if available
  if command -v omz >/dev/null 2>&1; then
    info "Updating Oh My Zsh..."
    omz update
    success "Oh My Zsh updated"
  fi
  
  # Update language versions if mise is available
  if command -v mise >/dev/null 2>&1; then
    info "Updating language versions..."
    mise install
    success "Language versions updated"
  fi
  
  success "Comprehensive dotfiles update completed!"
}

cmd_backup() {
  local backup_dir="$HOME/.dotfiles-backup-$(date +%Y%m%d-%H%M%S)"
  local force=${1:-false}
  
  info "Creating backup at $backup_dir..."
  
  if [ "$force" != "true" ]; then
    printf "This will backup your current dotfiles. Continue? [y/N] "
    read -r response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
      info "Backup cancelled"
      return 0
    fi
  fi
  
  mkdir -p "$backup_dir"
  
  # Backup existing dotfiles
  
  # Backup files and directories managed by new convention
  
  # Backup home directory .symlink files  
  for src in $(find -H "$DOTFILES_ROOT" -name '*.symlink' -not -path '*.git*' -not -path '*/config/*'); do
    filename=$(basename "${src%.*}")
    original="$HOME/.$filename"
    
    if [ -e "$original" ]; then
      backup_path="$backup_dir"
      mkdir -p "$backup_path"
      cp -r "$original" "$backup_path/"
      info "Backed up $original"
    fi
  done
  
  # Backup config directories and files
  for topic_dir in "$DOTFILES_ROOT"/*/; do
    topic=$(basename "$topic_dir")
    
    # Check for .symlink.d directories
    if [ -d "$topic_dir/config/$topic.symlink.d" ]; then
      original="$HOME/.config/$topic"
      if [ -e "$original" ]; then
        backup_path="$backup_dir/.config"
        mkdir -p "$backup_path"
        cp -r "$original" "$backup_path/${topic}-backup"
        info "Backed up $original directory"
      fi
    fi
    
    # Check for single .symlink config files
    if [ -f "$topic_dir/config/$topic.symlink" ]; then
      original="$HOME/.config/$topic.toml"
      if [ -e "$original" ]; then
        backup_path="$backup_dir/.config"
        mkdir -p "$backup_path"
        cp -r "$original" "$backup_path/"
        info "Backed up $original"
      fi
    fi
  done
  
  success "Backup created at $backup_dir"
}

cmd_clean() {
  info "Cleaning broken symlinks and old backups..."
  
  local cleaned_links=0
  local cleaned_backups=0
  
  # Clean broken symlinks using new convention
  
  # Clean home directory .symlink files
  for src in $(find -H "$DOTFILES_ROOT" -name '*.symlink' -not -path '*.git*' -not -path '*/config/*'); do
    filename=$(basename "${src%.*}")
    dst="$HOME/.$filename"
    
    if [ -L "$dst" ] && [ ! -e "$dst" ]; then
      rm "$dst"
      info "Removed broken symlink: $dst"
      cleaned_links=$((cleaned_links + 1))
    fi
  done
  
  # Clean config directory and file symlinks
  for topic_dir in "$DOTFILES_ROOT"/*/; do
    topic=$(basename "$topic_dir")
    
    # Check .symlink.d directories
    if [ -d "$topic_dir/config/$topic.symlink.d" ]; then
      dst="$HOME/.config/$topic"
      if [ -L "$dst" ] && [ ! -e "$dst" ]; then
        rm "$dst"
        info "Removed broken config directory symlink: $dst"
        cleaned_links=$((cleaned_links + 1))
      fi
    fi
    
    # Check single .symlink config files
    if [ -f "$topic_dir/config/$topic.symlink" ]; then
      dst="$HOME/.config/$topic.toml"
      if [ -L "$dst" ] && [ ! -e "$dst" ]; then
        rm "$dst"
        info "Removed broken config file symlink: $dst"
        cleaned_links=$((cleaned_links + 1))
      fi
    fi
  done
  
  # Clean old backup files in dotfiles directory
  info "Cleaning old backup files in dotfiles directory..."
  
  # Remove timestamped backups older than 30 days
  find "$DOTFILES_ROOT" -name "*.backup.*_*" -type f -mtime +30 2>/dev/null | while read -r backup_file; do
    rm "$backup_file"
    info "Removed old backup: $backup_file"
    cleaned_backups=$((cleaned_backups + 1))
  done
  
  # Look for duplicate .backup files and offer to clean them
  find "$DOTFILES_ROOT" -name "*.backup" -type f 2>/dev/null | while read -r backup_file; do
    base_name="${backup_file%.backup}"
    if [ -f "$base_name" ]; then
      echo "Found backup file: $backup_file"
      echo "Original exists: $base_name"
      user "Remove backup file $backup_file? [y/N]"
      read -r response
      if [[ "$response" =~ ^[Yy]$ ]]; then
        rm "$backup_file"
        info "Removed backup: $backup_file"
        cleaned_backups=$((cleaned_backups + 1))
      fi
    fi
  done
  
  success "Cleaned $cleaned_links broken symlinks and $cleaned_backups backup files"
}

cmd_list() {
  info "Managed dotfiles:"
  echo ""
  
  echo "Home directory files (.symlink):"
  for src in $(find -H "$DOTFILES_ROOT" -name '*.symlink' -not -path '*.git*' -not -path '*/config/*'); do
    filename=$(basename "${src%.*}")
    dst="$HOME/.$filename"
    
    if [ -L "$dst" ] && [ -e "$dst" ]; then
      printf "  \033[00;32m✓\033[0m %s\n" "${dst#$HOME/}"
    elif [ -L "$dst" ]; then
      printf "  \033[0;31m✗\033[0m %s (broken)\n" "${dst#$HOME/}"
    else
      printf "  \033[0;33m-\033[0m %s (missing)\n" "${dst#$HOME/}"
    fi
  done
  
  echo ""
  echo "Config directories (.symlink.d):"
  for topic_dir in "$DOTFILES_ROOT"/*/; do
    topic=$(basename "$topic_dir")
    if [ -d "$topic_dir/config/$topic.symlink.d" ]; then
      dst="$HOME/.config/$topic"
      if [ -L "$dst" ] && [ -e "$dst" ]; then
        printf "  \033[00;32m✓\033[0m .config/%s/ (directory)\n" "$topic"
      elif [ -L "$dst" ]; then
        printf "  \033[0;31m✗\033[0m .config/%s/ (broken)\n" "$topic"
      else
        printf "  \033[0;33m-\033[0m .config/%s/ (missing)\n" "$topic"
      fi
    fi
  done
  
  echo ""
  echo "Config files (.symlink):"
  for topic_dir in "$DOTFILES_ROOT"/*/; do
    topic=$(basename "$topic_dir")
    if [ -f "$topic_dir/config/$topic.symlink" ]; then
      dst="$HOME/.config/$topic.toml"
      if [ -L "$dst" ] && [ -e "$dst" ]; then
        printf "  \033[00;32m✓\033[0m .config/%s.toml\n" "$topic"
      elif [ -L "$dst" ]; then
        printf "  \033[0;31m✗\033[0m .config/%s.toml (broken)\n" "$topic"
      else
        printf "  \033[0;33m-\033[0m .config/%s.toml (missing)\n" "$topic"
      fi
    fi
  done
}

# Parse arguments
command=${1:-help}
shift || true

case $command in
  bootstrap)   cmd_bootstrap "$@" ;;
  install)     cmd_install "$@" ;;
  link)        cmd_link "$@" ;;
  update)      cmd_update "$@" ;;
  backup)      cmd_backup "$@" ;;
  clean)       cmd_clean "$@" ;;
  list)        cmd_list "$@" ;;
  help|--help|-h) show_help ;;
  *)
    echo "Unknown command: $command"
    echo "Run './script/dotfiles help' for usage information"
    exit 1
    ;;
esac

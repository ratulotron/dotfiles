#!/usr/bin/env bash
#
# Install all tools and dependencies

set -e

cd "$(dirname $0)"/..

show_help() {
  cat << EOF
install - Install all tools and dependencies

USAGE:
    ./script/install [options]

OPTIONS:
    --dry-run       Preview what would be done
    --help          Show this help message

EXAMPLES:
    ./script/install                    # Install all tools
    ./script/install --dry-run          # Preview installation
EOF
}

# Parse arguments
DRY_RUN=false

for arg in "$@"; do
  case $arg in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
  esac
done

echo "› installing tools and dependencies"

# Install Homebrew packages
if [ "$DRY_RUN" = "true" ]; then
  echo "› [DRY RUN] Would run: brew bundle"
else
  echo "› brew bundle"
  # Temporarily disable exit-on-error for brew bundle
  set +e
  brew bundle
  brew_exit_code=$?
  set -e
  
  if [ $brew_exit_code -eq 0 ]; then
    echo "› brew bundle completed successfully"
  else
    echo "› WARNING: brew bundle failed (exit code $brew_exit_code), but continuing with installation..."
    echo "› You may need to manually install some packages later"
    echo "› Run 'brew bundle' manually to see specific errors"
  fi
fi

# Run topic install scripts  
echo "› running topic install scripts"
find . -name install.sh | while read installer ; do 
  if [ "$DRY_RUN" = "true" ]; then
    echo "  › [DRY RUN] Would run: $installer"
  else
    echo "  › running $installer"
    # Temporarily disable exit-on-error for individual installers
    set +e
    sh -c "${installer}"
    install_exit_code=$?
    set -e
    
    if [ $install_exit_code -eq 0 ]; then
      echo "  › $installer completed successfully"
    else
      echo "  › WARNING: $installer failed (exit code $install_exit_code), but continuing..."
      echo "  › You may need to run $installer manually later"
    fi
  fi
done

if [ "$DRY_RUN" = "true" ]; then
  echo "› dry run complete!"
else
  echo "› tool installation complete!"
fi
